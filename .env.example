VITE_INVO_APP_MODE=development
VITE_INVO_INDEXER_URL=
VITE_INVO_RECEIVABLE_PACKAGE_ID=
VITE_INVO_RECEIVABLE_MODULE=receivable
VITE_INVO_ESCROW_MODULE=receivable_escrow
VITE_INVO_INVOICE_COUNTER_ID=
VITE_INVO_PLATFORM_CONFIG_ID=
# Settlement coin. Receivables are denominated and settled in USDC; gas is still
# paid in SUI on the Sui network. Defaults to Sui Testnet USDC (Circle).
# Mainnet native USDC: 0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
VITE_INVO_PAYMENT_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
VITE_INVO_PAYMENT_COIN_SYMBOL=USDC
VITE_INVO_PAYMENT_COIN_DECIMALS=6
# Platform fee shown in the UI. Must match the on-chain PlatformConfig
# (fee_recipient / fee_bps), which is set with `update_platform_fee`.
VITE_INVO_FEE_RECIPIENT=0x...
VITE_INVO_PLATFORM_FEE_BPS=100
# Gas sponsorship (optional). When set, transactions route through the backend
# sponsor so users only need USDC (no SUI for gas). Leave empty to have the
# connected wallet pay its own SUI gas. Only runs under Cloudflare / wrangler.
VITE_INVO_SPONSOR_URL=
# Public address only; never put the sponsor private key in a VITE_ variable.
# When this wallet is connected as an app actor, the frontend uses a normal
# single-signature transaction instead of asking the backend to sign twice.
VITE_INVO_SPONSOR_ADDRESS=0x...
# Server-side ONLY (Cloudflare Pages Function secret). The sponsor wallet's
# private key in `suiprivkey1...` form. Fund this wallet with SUI. NEVER prefix
# with VITE_ and never commit it.
# SPONSOR_PRIVATE_KEY=suiprivkey1...
VITE_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
VITE_WALRUS_STORAGE_EPOCHS=5
VITE_SUPABASE_URL=your_project_url
VITE_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_URL=your_project_url
SUPABASE_SERVICE_ROLE_KEY=server_side_only_service_role_key
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
RECEIVABLE_PACKAGE_ID=
RECEIVABLE_MODULE=receivable
RECEIVABLE_ESCROW_MODULE=receivable_escrow
# Client invoice email notifications. Server-side ONLY. The app uses MailerSend
# from Cloudflare Pages Functions after a verified InvoiceCreated sync.
# MAILERSEND_API_KEY=mlsn_...
INVOICE_EMAIL_FROM=InvoNFT <invoices@your-domain.com>
INVOICE_REPLY_TO=support@your-domain.com
INVO_PUBLIC_APP_URL=https://your-cloudflare-pages-domain.pages.dev
